# ─────────────────────────────────────────────────────────────────────────────
# job-agent configuration — copy to ".env" and fill in real values.
# job_agent.sh sources this file and exports everything to the python steps.
# Do NOT commit the real .env (it is gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM API keys ─────────────────────────────────────────────────────────────
# Google Gemini key used by rank_jobs.py
GOOGLE_API_KEY=
# Second Gemini key used by cover_letter.py (can mirror GOOGLE_API_KEY)
GOOGLE_API_KEY2=
# Groq key used by rank_jobs.py and cover_letter.py
GROQ_API_KEY=

# GitHub Models token — used by resume_builder.py via the OpenAI SDK against
# https://models.inference.ai.azure.com  (create at https://github.com/settings/tokens)
GITHUB_TOKEN=

# Where rank_jobs.py caches the Gemini chat session
GEMINI_SESSION_FILE=/tmp/gemini_chat_session.json

# ── Email report (email_report.py) ───────────────────────────────────────────
SENDER_EMAIL=mhaiderzaidi21@gmail.com
RECEIVER_EMAIL=mhaiderzaidi21@gmail.com
# Gmail App Password (16 chars, NOT your normal password) — https://myaccount.google.com/apppasswords
GMAIL_APP=
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
